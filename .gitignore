*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
.env
.venv/
env/
venv/

# ── Dataset (large files — do not commit raw data) ────────────────────────────
dataset/
*.jpg
*.jpeg
*.png
*.bmp
*.tiff
*.tif
*.mp4
*.avi
*.mov

# ── COCO annotation JSON (can be 50 MB+) ─────────────────────────────────────
coco.json
index.json

# ── Model weights ─────────────────────────────────────────────────────────────
*.pt
*.pth
*.onnx
*.engine
*.torchscript

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store

# ── YOLO training runs (exceptions — must be LAST to override rules above) ──
# Track outputs/weights under any module path, e.g. ADAS/runs or FLS/*/runs.
!**/runs/
!**/runs/**
!**/runs/**/*.pt
!**/runs/**/*.pth
!**/runs/**/*.onnx
!**/runs/**/*.jpg
!**/runs/**/*.jpeg
!**/runs/**/*.png
!**/runs/**/*.bmp
!**/runs/**/*.tiff
!**/runs/**/*.tif
!**/runs/**/weights/
!**/runs/**/weights/*
Thumbs.db
desktop.ini

# ── Misc ─────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
